{
  "name": "ship",
  "private": true,
  "scripts": {
    "dev": "docker compose up -d && concurrently \"pnpm --filter @ship/api dev\" \"pnpm --filter @ship/web dev\"",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "db:migrate": "pnpm --filter @ship/api db:migrate",
    "db:seed": "pnpm --filter @ship/api db:seed"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "typescript": "^5.7.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
